{
  "expo": {
    "name": "TimeKeep",
    "slug": "timekeep",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "timekeep",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
